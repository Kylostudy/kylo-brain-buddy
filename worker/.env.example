# A KyloKit worker konfigurációja a saját VPS-en.
# Másold ezt .env-re és töltsd ki.

# A Lovable Cloud-on futó Brain publikus címe (custom domain vagy lovable.app):
BRAIN_URL=https://brain.kylosystems.com

# Megosztott titok a worker <-> Brain hitelesítéshez.
# Pontosan ugyanaz az érték, mint a Lovable secret store-ban.
WORKER_API_TOKEN=REPLACE_WITH_TOKEN

# Saját azonosító (csak logolásra), pl. worker-1, worker-budapest stb.
WORKER_ID=worker-1

# Hány workflow fusson párhuzamosan ezen a gépen.
MAX_PARALLEL=4

# Milyen sűrűn nézzen új jobot (ms).
POLL_INTERVAL_MS=3000
