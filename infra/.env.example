# =============================================================================
# Kylo Systems — Környezeti változók (.env fájl)
# Másold ezt .env néven:  cp .env.example .env
# és írd be a saját értékeidet!
# =============================================================================

# --- Adatbázis ---------------------------------------------------------------
POSTGRES_DB=kylo
POSTGRES_USER=kylo
# ⚠️ FONTOS: Változtasd meg ezt a jelszót! Használj erős, véletlenszerű jelszót!
POSTGRES_PASSWORD=VALTOZTASD_MEG_EZT_A_JELSZOT

# --- Redis -------------------------------------------------------------------
# Redis jelszó (opcionális, de ajánlott élesben)
# REDIS_PASSWORD=masik_erős_jelszo

# --- KyloBrain API kulcsok ---------------------------------------------------
# Google Gemini API kulcs (a LEGO könyvtár és kódgenerálás működéséhez szükséges)
GEMINI_API_KEY=te_gemini_api_kulcsod_ide

# --- KyloKit session korlátok ------------------------------------------------
# Maximum hány párhuzamos Playwright session futhat egyszerre
MAX_PARALLEL_SESSIONS=5

# --- Biztonság ---------------------------------------------------------------
# Session titkosítási kulcs (generálj véletlenszerű 64 karaktert: openssl rand -hex 32)
SESSION_SECRET=generálj_egy_64_karakteres_véletlenszerű_kulcsot

# --- Steel.dev (átmeneti, amíg teljesen át nem állunk) -----------------------
# Ha még használod a Steel.dev-et, add meg az API kulcsot
# STEEL_API_KEY=te_steel_api_kulcsod

# --- Email értesítések (opcionális) ------------------------------------------
# SMTP beállítások hibajelentésekhez
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=te_email_cimed
# SMTP_PASS=te_email_jelszavad
